{
  "expo": {
    "name": "ABA",
    "slug": "ABA",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "aba",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.astawusamsalu.aba",
      "infoPlist": {
        "NSCameraUsageDescription": "ABA needs access to your camera for video calls.",
        "NSMicrophoneUsageDescription": "ABA needs access to your microphone for audio and video calls.",
        "NSContactsUsageDescription": "ABA needs access to your contacts to find friends."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.astawusamsalu.aba",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "READ_CONTACTS",
        "WRITE_CONTACTS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
  
    "owner": "astawusamsalu",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "77d9f914-7250-4714-9b30-02afa7066a6d"
      }
    }
  }
}
